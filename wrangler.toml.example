name = "google-docs-mcp"
main = "src/index.ts"
compatibility_date = "2024-09-23"
compatibility_flags = ["nodejs_compat"]
workers_dev = false
preview_urls = true

[observability]
enabled = true
head_sampling_rate = 1

[[kv_namespaces]]
binding = "TOKENS"
id = "YOUR_KV_NAMESPACE_ID"  # wrangler kv namespace create TOKENS

[[durable_objects.bindings]]
name = "MCP_SESSION"
class_name = "MCPSession"

[[migrations]]
tag = "v1"
new_classes = ["MCPSession"]

[vars]
GOOGLE_REDIRECT_URI = "https://YOUR_WORKER_SUBDOMAIN.workers.dev/auth/callback"
# GOOGLE_CLIENT_ID and GOOGLE_CLIENT_SECRET should be set via wrangler secret
